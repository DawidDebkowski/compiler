PROGRAM IS
    a, b, c, d
IN
    a := 5;
    b := 6;
    c := 10;
    d := 4;
    IF a = 5 THEN WRITE 1; ENDIF
    IF b = 6 THEN WRITE 2; ENDIF
    IF a != d THEN WRITE 3; ENDIF
    IF b != a THEN WRITE 4; ENDIF
    IF a < c THEN WRITE 5; ENDIF
    IF d < a THEN WRITE 6; ENDIF
    IF c > a THEN WRITE 7; ENDIF
    IF b > d THEN WRITE 8; ENDIF
    IF a <= 5 THEN WRITE 9; ENDIF
    IF d <= a THEN WRITE 10; ENDIF
    IF a >= 5 THEN WRITE 11; ENDIF
    IF c >= a THEN WRITE 12; ENDIF
    IF a = 6 THEN WRITE 0; ELSE WRITE 13; ENDIF
    IF b = 5 THEN WRITE 0; ELSE WRITE 14; ENDIF
    IF a = d THEN WRITE 0; ELSE WRITE 15; ENDIF
    IF b = a THEN WRITE 0; ELSE WRITE 16; ENDIF
    IF a > c THEN WRITE 0; ELSE WRITE 17; ENDIF
    IF d > a THEN WRITE 0; ELSE WRITE 18; ENDIF
    IF c < a THEN WRITE 0; ELSE WRITE 19; ENDIF
    IF b < d THEN WRITE 0; ELSE WRITE 20; ENDIF
    IF a > 5 THEN WRITE 0; ELSE WRITE 21; ENDIF
    IF d > a THEN WRITE 0; ELSE WRITE 22; ENDIF
    IF a < 5 THEN WRITE 0; ELSE WRITE 23; ENDIF
    IF c < a THEN WRITE 0; ELSE WRITE 24; ENDIF
END