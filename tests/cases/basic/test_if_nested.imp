PROGRAM IS
    x, y, z
IN
    x := 1;
    y := 2;
    z := 3;
    IF x = 1 THEN
        WRITE 1;
        IF y = 2 THEN
            WRITE 2;
            IF z = 3 THEN
                WRITE 3;
            ELSE
                WRITE 0;
            ENDIF
        ELSE
            WRITE 0;
        ENDIF
    ELSE
        WRITE 0;
    ENDIF
    IF x != 1 THEN
        WRITE 0;
    ELSE
        WRITE 4;
        IF y != 2 THEN
            WRITE 0;
        ELSE
            WRITE 5;
            IF z != 3 THEN
                WRITE 0;
            ELSE
                WRITE 6;
            ENDIF
        ENDIF
    ENDIF
END