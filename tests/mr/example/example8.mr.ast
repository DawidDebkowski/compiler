Program
  Procedures:
    Procedure shuffle
      Assignment
        Identifier(q)
        Number(5)
      Assignment
        Identifier(w)
        Number(1)
      For(i TO)
        From:
          Number(1)
        To:
          Identifier(n)
      Do
        Assignment
          Identifier(w)
          BinaryOp(*)
            Identifier(w)
            Identifier(q)
        Assignment
          Identifier(w)
          BinaryOp(%)
            Identifier(w)
            Identifier(n)
        Assignment
          Identifier(t[i])
          Identifier(w)
      Assignment
        Identifier(t[n])
        Number(0)
    Procedure sort
      For(i TO)
        From:
          Number(2)
        To:
          Identifier(n)
      Do
        Assignment
          Identifier(x)
          Identifier(t[i])
        Assignment
          Identifier(j)
          Identifier(i)
        While
          Condition(>)
            Identifier(j)
            Number(1)
        Do
          Assignment
            Identifier(k)
            BinaryOp(-)
              Identifier(j)
              Number(1)
          If
            Condition(>)
              Identifier(t[k])
              Identifier(x)
          Then
            Assignment
              Identifier(t[j])
              Identifier(t[k])
            Assignment
              Identifier(j)
              BinaryOp(-)
                Identifier(j)
                Number(1)
          Else
            Assignment
              Identifier(k)
              Identifier(j)
            Assignment
              Identifier(j)
              Number(1)
        Assignment
          Identifier(t[k])
          Identifier(x)
    Procedure write
      For(i TO)
        From:
          Number(1)
        To:
          Identifier(n)
      Do
        Write
          Identifier(t[i])
  Main:
    Assignment
      Identifier(n)
      Number(23)
    ProcCall(shuffle)
      Identifier(t)
      Identifier(n)
    ProcCall(write)
      Identifier(t)
      Identifier(n)
    Write
      Number(1234567890)
    ProcCall(sort)
      Identifier(t)
      Identifier(n)
    ProcCall(write)
      Identifier(t)
      Identifier(n)
