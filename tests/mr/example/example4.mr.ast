Program
  Procedures:
    Procedure s
      Assignment
        Identifier(m)
        Number(1)
      For(i DOWNTO)
        From:
          Identifier(n)
        To:
          Number(2)
      Do
        Assignment
          Identifier(o)
          BinaryOp(%)
            Identifier(i)
            Number(2)
        If
          Condition(=)
            Identifier(o)
            Number(1)
        Then
          Assignment
            Identifier(m)
            BinaryOp(*)
              Identifier(m)
              Identifier(i)
        Else
          Assignment
            Identifier(m)
            BinaryOp(*)
              Identifier(i)
              Identifier(m)
    Procedure bc
      ProcCall(s)
        Identifier(n)
        Identifier(a)
      Assignment
        Identifier(p)
        BinaryOp(-)
          Identifier(n)
          Identifier(k)
      ProcCall(s)
        Identifier(p)
        Identifier(b)
      ProcCall(s)
        Identifier(k)
        Identifier(c)
      Assignment
        Identifier(m)
        BinaryOp(/)
          Identifier(a)
          Identifier(b)
      Assignment
        Identifier(m)
        BinaryOp(/)
          Identifier(m)
          Identifier(c)
  Main:
    Read
      Identifier(n)
    Read
      Identifier(k)
    ProcCall(bc)
      Identifier(n)
      Identifier(k)
      Identifier(w)
    Write
      Identifier(w)
